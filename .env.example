# Gemini API（从 Google AI Studio 获取：https://aistudio.google.com/apikey）
GEMINI_API_KEY=

# 飞书应用（从飞书开放平台获取：https://open.feishu.cn/）
FEISHU_APP_ID=
FEISHU_APP_SECRET=
FEISHU_CHAT_ID=           # 接收通知的群聊 ID（oc_xxx）
FEISHU_FOLDER_TOKEN=      # 存放学习笔记的文件夹 token

# YouTube OAuth（从 Google Cloud Console 获取：https://console.cloud.google.com/）
# 需要启用 YouTube Data API v3，创建 OAuth 2.0 桌面应用凭据
YOUTUBE_CLIENT_ID=
YOUTUBE_CLIENT_SECRET=
